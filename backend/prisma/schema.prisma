generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(0)
  description String?
  created_at  DateTime @default(now())

  @@index([name])
  @@index([created_at])
  @@map("products")
}
